generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                 @id @default(cuid())
  clerkId              String?                @unique
  email                String                 @unique
  name                 String?
  password             String?
  image                String?
  emailVerified        DateTime?
  onboardingCompleted  Boolean                @default(false)
  onboardingData       Json?
  hasSeenIntro         Boolean                @default(false)
  welcomeMessageSent   Boolean                @default(false)
  welcomeMessageSentAt DateTime?
  isDeleted            Boolean                @default(false)
  deletedAt            DateTime?
  deletionReason       String?
  dataRetentionUntil   DateTime?
  canRecover           Boolean                @default(true)
  subscriptionStatus   String?                @default("free")
  subscriptionId       String?
  billingEmail         String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  stripeCustomerId     String?
  concurrentSessions   Int?                   @default(1)
  maxSessionDuration   Int?                   @default(30)
  AIInsight            AIInsight[]
  auditLogs            AuditLog[]
  calendarIntegrations CalendarIntegration[]
  communicationMetrics CommunicationMetric[]
  creditReservations   CreditReservation[]
  DailyTip             DailyTip[]
  DynamicGoal          DynamicGoal[]
  familyMembers        FamilyMember[]
  InsightPattern       InsightPattern[]
  notificationTracking NotificationTracking[]
  progressTracking     ProgressTracking[]
  smsOptOuts           SMSOptOut[]
  sessions             Session[]
  sessionMetrics       SessionMetrics[]
  therapyInsights      TherapyInsight[]
  usageAlerts          UsageAlert[]
  usageCredits         UsageCredits[]
  usageTransactions    UsageTransaction[]
  profile              UserProfile?

  @@index([clerkId])
  @@index([email])
  @@index([createdAt])
  @@index([isDeleted, deletedAt])
  @@index([subscriptionStatus])
  @@index([dataRetentionUntil])
}

model UserProfile {
  id                   String    @id @default(cuid())
  userId               String    @unique
  pronouns             String?
  age                  Int?
  phone                String?
  emergencyContact     String?
  sessionPreference    String?
  communicationStyle   String?
  notificationPrefs    Json?     @default("[]")
  sessionFrequency     String?
  preferredDays        Json?
  recurringSession     String?
  reminderTiming       String?
  smsConsent           Boolean?  @default(false)
  smsConsentDate       DateTime?
  phoneValidated       Boolean?  @default(false)
  partnerName          String?
  partnerAge           Int?
  relationshipStatus   String?   @default("Married")
  currentConcerns      Json?
  additionalNotes      String?
  assistantId          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  aiDisclaimerAccepted Boolean   @default(false)
  aiDisclaimerDate     DateTime?
  aiDisclaimerVersion  String?
  timezone             String?   @default("UTC")
  version              Int       @default(0)
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assistantId])
}

model FamilyMember {
  id                   String                @id @default(cuid())
  userId               String
  name                 String
  age                  Int?
  relationship         String
  order                Int                   @default(0)
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionFamilyMembers SessionFamilyMember[]

  @@unique([userId, name])
  @@index([userId, isActive])
  @@index([userId, order])
}

model Session {
  id                      String                 @id @default(uuid())
  userId                  String
  assistantId             String?
  date                    DateTime
  startTime               DateTime?
  endTime                 DateTime?
  completedAt             DateTime?
  duration                Int                    @default(30)
  theme                   String                 @default("AI Therapy Session")
  notes                   String?                @default("")
  status                  SessionStatus          @default(SCHEDULED)
  terminationReason       String?
  conversationTimeSeconds Int                    @default(0)
  lastConversationStart   DateTime?
  isPaused                Boolean                @default(false)
  pausedAt                DateTime?
  resumedAt               DateTime?
  totalPausedTimeSeconds  Int                    @default(0)
  pauseStartTime          DateTime?
  vapiCallId              String?
  vapiCallCost            Float?
  vapiRecordingUrl        String?
  reminderSent            Boolean                @default(false)
  smsReminderSent         Boolean?               @default(false)
  emailReminderSent       Boolean?               @default(false)
  oneHourReminderSent     Boolean?               @default(false)
  version                 Int                    @default(0)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  sessionType             SessionType            @default(SOLO)
  notificationStartedAt   DateTime?
  notificationToken       String?
  notificationTokenExpiry DateTime?
  startedViaNotification  Boolean                @default(false)
  creditsAllocated        Int?                   @default(0)
  creditsUsed             Int?                   @default(0)
  AIInsight               AIInsight[]
  communicationMetrics    CommunicationMetric[]
  notificationTracking    NotificationTracking[]
  progressTracking        ProgressTracking[]
  user                    User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionFamilyMembers    SessionFamilyMember[]
  sessionMetrics          SessionMetrics?
  SessionSummary          SessionSummary?
  therapyInsights         TherapyInsight[]
  transcriptEntries       TranscriptEntry[]
  usageTransactions       UsageTransaction[]
  conversationState       ConversationState?

  @@index([userId, status])
  @@index([userId, startTime])
  @@index([userId, sessionType])
  @@index([userId, status, sessionType])
  @@index([userId, status, date])
  @@index([assistantId])
  @@index([status, startTime])
  @@index([notificationToken])
  @@index([completedAt])
  @@index([vapiCallId])
}

model SessionFamilyMember {
  id                 String       @id @default(cuid())
  sessionId          String
  familyMemberId     String
  participationLevel String?      @default("active")
  createdAt          DateTime     @default(now())
  familyMember       FamilyMember @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  session            Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, familyMemberId])
  @@index([sessionId])
  @@index([familyMemberId])
}

model CommunicationMetric {
  id           String   @id @default(cuid())
  sessionId    String?
  userId       String
  clarity      Float    @default(50)
  empathy      Float    @default(50)
  respect      Float    @default(50)
  overall      Float    @default(50)
  listening    Float?   @default(50)
  expression   Float?   @default(50)
  metricType   String   @default("real-time")
  calculatedAt DateTime @default(now())
  confidence   Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  session      Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId, metricType])
  @@index([sessionId, calculatedAt])
  @@index([userId, calculatedAt])
  @@index([userId, metricType, calculatedAt])
}

model SessionMetrics {
  id                    String   @id @default(cuid())
  sessionId             String   @unique
  userId                String
  duration              Int      @default(0)
  totalMessages         Int      @default(0)
  userMessages          Int      @default(0)
  assistantMessages     Int      @default(0)
  engagementScore       Float    @default(0)
  sentimentScore        Float    @default(0)
  sentimentTrend        String   @default("neutral")
  topicsCovered         String[]
  emotionalInsights     Json?
  completionRate        Float    @default(1.0)
  qualityScore          Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  activeListening       Float    @default(0)
  clarity               Float    @default(0)
  emotionalPatterns     String[]
  empathy               Float    @default(0)
  keyTopics             String[]
  respect               Float    @default(0)
  therapistSpeakingTime Int      @default(0)
  therapistWordCount    Int      @default(0)
  userSpeakingTime      Int      @default(0)
  userWordCount         Int      @default(0)
  session               Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ProgressTracking {
  id                 String   @id @default(cuid())
  userId             String
  sessionId          String?
  closenessScore     Int
  communicationScore Int
  notes              String?
  assistantId        String?
  date               DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  session            Session? @relation(fields: [sessionId], references: [id])
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])
  @@index([userId, date])
  @@index([assistantId])
}

model TranscriptEntry {
  id                 String   @id @default(cuid())
  sessionId          String
  speaker            String
  text               String
  timestamp          DateTime @default(now())
  isFinal            Boolean  @default(true)
  assistantId        String?
  sequence           Int?
  sentiment          String?
  emotionalIntensity Float?
  topics             Json?
  createdAt          DateTime @default(now())
  session            Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@index([sessionId, sequence])
  @@index([timestamp])
  @@index([assistantId])
}

model ConversationState {
  id               String                @id @default(cuid())
  sessionId        String                @unique
  userId           String
  assistantId      String
  variableValues   Json?
  metadata         Json?
  sessionStartTime DateTime
  lastActiveTime   DateTime
  totalDuration    Int                   @default(0)
  messageCount     Int                   @default(0)
  isActive         Boolean               @default(false)
  isPaused         Boolean               @default(true)
  expiresAt        DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  messages         ConversationMessage[]
  session          Session               @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, isPaused])
  @@index([userId, lastActiveTime])
  @@index([expiresAt])
  @@map("conversation_states")
}

model ConversationMessage {
  id                  String            @id @default(cuid())
  conversationStateId String
  role                String
  content             String
  timestamp           DateTime          @default(now())
  metadata            Json?
  conversationState   ConversationState @relation(fields: [conversationStateId], references: [id], onDelete: Cascade)

  @@index([conversationStateId, timestamp])
  @@map("conversation_messages")
}


model SMSOptOut {
  id          String    @id @default(cuid())
  phoneNumber String
  userId      String?
  keyword     String
  optOutAt    DateTime  @default(now())
  optInAt     DateTime?
  active      Boolean   @default(true)
  source      String    @default("sms")
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User?     @relation(fields: [userId], references: [id])

  @@unique([phoneNumber, active])
  @@index([phoneNumber])
  @@index([userId])
  @@index([active, optOutAt])
}

model AuditLog {
  id              String    @id @default(cuid())
  userId          String?
  sessionId       String?
  action          String
  ipAddress       String?
  userAgent       String?
  requestId       String?
  metadata        Json?
  reason          String?
  complianceFlags String[]  @default([])
  isLegalHold     Boolean   @default(false)
  legalHoldUntil  DateTime?
  createdAt       DateTime  @default(now())
  changedFields   String[]
  entityId        String?
  entityType      String
  newValues       Json?
  oldValues       Json?
  user            User?     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([action, entityType])
  @@index([sessionId])
  @@index([createdAt])
  @@index([isLegalHold, legalHoldUntil])
}

model DataExportRequest {
  id                 String    @id @default(cuid())
  userId             String
  requestType        String    @default("full")
  status             String    @default("pending")
  format             String    @default("json")
  includeTranscripts Boolean   @default(true)
  includeMetrics     Boolean   @default(true)
  includeProfile     Boolean   @default(true)
  includeSessions    Boolean   @default(true)
  downloadUrl        String?
  expiresAt          DateTime?
  fileSize           Int?
  processedAt        DateTime?
  downloadedAt       DateTime?
  errorMessage       String?
  retryCount         Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([expiresAt])
}

model AccountRecovery {
  id              String    @id @default(cuid())
  userId          String    @unique
  email           String
  recoveryToken   String    @unique
  recoveryCode    String?
  expiresAt       DateTime
  userSnapshot    Json
  profileSnapshot Json?
  sessionCount    Int       @default(0)
  attemptCount    Int       @default(0)
  lastAttemptAt   DateTime?
  isRecovered     Boolean   @default(false)
  recoveredAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([recoveryToken])
  @@index([email, expiresAt])
  @@index([expiresAt, isRecovered])
}

model CalendarIntegration {
  id               String    @id @default(cuid())
  userId           String
  provider         String
  enabled          Boolean   @default(false)
  accountEmail     String?
  calendarId       String?
  accessToken      String?
  refreshToken     String?
  expiresAt        DateTime?
  lastSync         DateTime?
  syncStatus       String    @default("disconnected")
  errorMessage     String?
  providerMetadata Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId, enabled])
  @@index([provider, syncStatus])
  @@index([expiresAt])
}

model TherapyInsight {
  id              String   @id @default(cuid())
  sessionId       String?
  userId          String
  category        String
  title           String
  description     String
  priority        String   @default("medium")
  confidence      Float    @default(0.8)
  evidence        Json?
  recommendations Json?
  isRealTime      Boolean  @default(false)
  generatedAt     DateTime @default(now())
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  session         Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([sessionId, generatedAt])
  @@index([userId, generatedAt])
  @@index([isRealTime, generatedAt])
}

model Notification {
  id               String    @id @default(cuid())
  userId           String
  sessionId        String?
  type             String
  title            String
  message          String
  priority         String    @default("normal")
  deliveryMethod   String    @default("email")
  deliveryStatus   String    @default("pending")
  deliveryAttempts Int       @default(0)
  deliveredAt      DateTime?
  scheduledFor     DateTime?
  sentAt           DateTime?
  readAt           DateTime?
  actionUrl        String?
  actionTaken      String?
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId, type, deliveryStatus])
  @@index([userId, readAt])
  @@index([scheduledFor, deliveryStatus])
  @@index([sessionId])
}

model WebhookEvent {
  id            String    @id @default(cuid())
  webhookId     String    @unique
  messageType   String
  callId        String?
  sessionId     String?
  payload       Json
  status        String    @default("pending")
  processedAt   DateTime?
  error         String?
  retryCount    Int       @default(0)
  correlationId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([webhookId])
  @@index([sessionId])
  @@index([callId])
  @@index([status, createdAt])
  @@index([messageType, createdAt])
}

model TherapySession {
  id                String   @id @default(cuid())
  userId            String
  sessionDate       DateTime
  duration          Int
  notes             String?
  status            String   @default("scheduled")
  reminderSent      Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  notificationPrefs String?  @default("email")
  smsReminderSent   Boolean? @default(false)
  emailReminderSent Boolean? @default(false)

  @@index([userId])
  @@index([sessionDate])
  @@index([status])
}

model NotificationTracking {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  type      String
  action    String
  token     String?
  metadata  Json?
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@index([token])
}

model UsageCredits {
  id                 String              @id @default(cuid())
  userId             String
  totalCredits       Int                 @default(0)
  usedCredits        Int                 @default(0)
  bonusCredits       Int                 @default(0)
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  planType           String
  subscriptionId     String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  version            Int                 @default(0)
  reservations       CreditReservation[]
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions       UsageTransaction[]

  @@index([userId, billingPeriodStart, billingPeriodEnd])
  @@index([userId, createdAt])
  @@index([planType])
  @@index([userId, billingPeriodStart, billingPeriodEnd], map: "UsageCredits_userId_billingPeriod_idx")
}

model UsageTransaction {
  id          String          @id @default(cuid())
  userId      String
  creditId    String
  type        TransactionType
  amount      Int
  balance     Int
  sessionId   String?
  vapiCallId  String?
  description String
  metadata    Json?
  createdAt   DateTime        @default(now())
  credit      UsageCredits    @relation(fields: [creditId], references: [id], onDelete: Cascade)
  session     Session?        @relation(fields: [sessionId], references: [id])
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([vapiCallId])
  @@index([creditId, type])
}

model UsageAlert {
  id           String    @id @default(cuid())
  userId       String
  alertType    AlertType
  threshold    Int
  message      String
  acknowledged Boolean   @default(false)
  sentAt       DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, acknowledged])
  @@index([sentAt])
  @@index([alertType, threshold])
}

model CreditReservation {
  id        String            @id @default(cuid())
  userId    String
  sessionId String            @unique
  minutes   Int
  creditId  String
  expiresAt DateTime
  status    ReservationStatus @default(ACTIVE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  credit    UsageCredits      @relation(fields: [creditId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([sessionId])
  @@index([expiresAt])
  @@index([creditId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AIInsight {
  id                 String    @id
  sessionId          String
  userId             String
  type               String
  title              String
  description        String
  importance         String    @default("medium")
  actionable         Boolean   @default(false)
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime
  confidence         Float     @default(60.0)
  confidenceFactors  Json?
  disclaimerAccepted DateTime?
  disclaimerShown    Boolean   @default(false)
  enhancedConfidence Float?
  evidenceCount      Int       @default(0)
  therapistValidated Boolean   @default(false)
  userFeedbackScore  Float?
  Session            Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  User               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([confidence])
  @@index([createdAt])
  @@index([disclaimerShown])
  @@index([sessionId])
  @@index([therapistValidated])
  @@index([type])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model DailyTip {
  id              String    @id
  userId          String
  content         String
  category        String
  scheduledDate   DateTime
  isActive        Boolean   @default(true)
  isPersonalized  Boolean   @default(false)
  basedOnInsights String[]
  lastShownAt     DateTime?
  showCount       Int       @default(0)
  clickCount      Int       @default(0)
  helpfulRating   Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  User            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([scheduledDate])
  @@index([userId, category])
  @@index([userId, isActive, scheduledDate])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model DynamicGoal {
  id              String     @id
  userId          String
  title           String
  description     String
  category        String
  goalType        String
  targetDate      DateTime
  status          GoalStatus @default(ACTIVE)
  progress        Int        @default(0)
  milestones      Json?
  basedOnInsights String[]
  aiGenerated     Boolean    @default(true)
  completedAt     DateTime?
  metadata        Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime
  User            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([targetDate])
  @@index([userId, category, status])
  @@index([userId, status, targetDate])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model EmotionalMilestone {
  id            String   @id
  userId        String
  sessionId     String?
  milestoneType String
  emotionType   String
  intensity     Float    @default(0.5)
  description   String
  context       String?
  progressValue Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime

  @@index([createdAt])
  @@index([sessionId])
  @@index([userId, milestoneType])
  @@index([userId, sessionId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model InsightPattern {
  id              String   @id
  userId          String
  patternType     String
  title           String
  description     String
  frequency       Int      @default(1)
  lastObservedAt  DateTime @default(now())
  firstObservedAt DateTime @default(now())
  isPositive      Boolean
  confidence      Float    @default(0.5)
  evidence        Json
  relatedSessions String[]
  severity        String   @default("medium")
  actionable      Boolean  @default(true)
  status          String   @default("active")
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  User            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([confidence])
  @@index([lastObservedAt])
  @@index([userId, patternType, status])
  @@index([userId, status, isPositive])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model SessionSummary {
  id                    String   @id
  sessionId             String   @unique
  userId                String
  keyThemes             String[]
  emotionalJourney      Json
  breakthroughMoments   String[]
  progressMarkers       String[]
  challengeAreas        String[]
  nextSessionFocus      String?
  therapistNotes        String?
  contextForNextSession String?
  processingStatus      String   @default("pending")
  createdAt             DateTime @default(now())
  updatedAt             DateTime
  Session               Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([sessionId])
  @@index([userId, processingStatus])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TherapeuticBreakthrough {
  id               String   @id
  sessionId        String
  userId           String
  breakthroughType String
  intensity        Float    @default(0.5)
  description      String
  themes           String[]
  emotionalState   Json?
  context          String?
  confidence       Float    @default(0.7)
  aiGenerated      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime

  @@index([createdAt])
  @@index([sessionId])
  @@index([userId, breakthroughType])
  @@index([userId, sessionId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TherapeuticRelationship {
  id               String   @id
  userId           String
  relationshipType String
  fromSessionId    String
  toSessionId      String
  connectionType   String
  strength         Float    @default(0.5)
  description      String?
  evidence         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime

  @@index([createdAt])
  @@index([fromSessionId])
  @@index([toSessionId])
  @@index([userId, relationshipType])
}

enum SessionStatus {
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  TERMINATED
  ABANDONED
  TECHNICAL_ISSUE
}

enum SessionType {
  SOLO
  COUPLE
  FAMILY
}

enum TransactionType {
  DEBIT
  BONUS
  REFUND
}

enum AlertType {
  LOW_CREDITS
  CREDITS_EXHAUSTED
  BILLING_REMINDER
}

enum ReservationStatus {
  ACTIVE
  EXPIRED
  CONSUMED
  RELEASED
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  PAUSED
  OVERDUE
}

model Resource {
  id           String   @id @default(cuid())
  title        String
  description  String
  type         String   // article | exercise | technique | book | worksheet
  categories   String[] // communication | emotional | behavioral | mental-health | relationship | progress
  sessionTypes String[] // SOLO | COUPLE | FAMILY — empty means all types
  concerns     String[] // anxiety | depression | communication | trust | anger | grief | stress | self-esteem
  difficulty   String   @default("beginner") // beginner | intermediate | advanced
  source       String   // e.g. "NAMI", "Psychology Today", "GoodTherapy"
  url          String?
  duration     String?  // e.g. "10 minutes", "Daily"
  isExternal   Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([categories])
  @@index([sessionTypes])
  @@index([concerns])
  @@index([type])
}
