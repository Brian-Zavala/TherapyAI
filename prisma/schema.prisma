generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  name                  String?
  password              String?
  partnerName           String?
  relationshipStatus    String?                @default("Married")
  assistantId           String?
  familyMember1         String?
  familyMember2         String?
  familyMember3         String?
  familyMember4         String?
  image                 String?
  emailVerified         DateTime?
  onboardingCompleted   Boolean                @default(false)
  onboardingData        Json?
  pronouns              String?
  therapyType           String?
  currentConcerns       Json?
  emergencyContact      String?
  sessionPreference     String?
  communicationStyle    String?
  additionalNotes       String?
  phone                 String?
  notificationPrefs     String?                @default("email")
  age                   Int?
  partnerAge            Int?
  familyMember1Age      Int?
  familyMember2Age      Int?
  familyMember3Age      Int?
  familyMember4Age      Int?
  hasSeenIntro          Boolean                @default(false)
  familyMember1Relation String?
  familyMember2Relation String?
  familyMember3Relation String?
  familyMember4Relation String?
  familyMember5         String?
  familyMember5Age      Int?
  familyMember5Relation String?
  familyMember6         String?
  familyMember6Age      Int?
  familyMember6Relation String?
  familyMember7         String?
  familyMember7Age      Int?
  familyMember7Relation String?
  preferredDays         Json?
  recurringSession      String?
  reminderTiming        String?
  sessionFrequency      String?
  accounts              Account[]
  authSessions          AuthSession[]
  communicationMetrics  CommunicationMetrics[]
  progressTracking      ProgressTracking[]
  sessions              Session[]
  therapySessions       TherapySession[]
}

model Session {
  id                     String            @id @default(uuid())
  userId                 String
  date                   DateTime
  duration               Int
  theme                  String            @default("AI Therapy Session")
  notes                  String?           @default("")
  status                 String            @default("scheduled")
  reminderSent           Boolean           @default(false)
  transcript             String?
  notificationPrefs      String?           @default("email")
  smsReminderSent        Boolean?          @default(false)
  emailReminderSent      Boolean?          @default(false)
  assistantId            String?
  oneHourReminderSent    Boolean?          @default(false)
  startTime              DateTime?
  conversationTimeSeconds Int              @default(0)  // Accumulated actual conversation time
  lastConversationStart   DateTime?                     // When current conversation segment started
  isPaused               Boolean           @default(false) // Whether conversation is currently paused
  pausedAt               DateTime?                         // When session was last paused
  resumedAt              DateTime?                         // When session was last resumed
  totalPausedTimeSeconds Int               @default(0)     // Total accumulated pause time
  pauseStartTime         DateTime?                         // When current pause started (for tracking)
  user                   User              @relation(fields: [userId], references: [id])
  transcriptEntries      TranscriptEntry[]

  @@index([userId])
  @@index([assistantId])
}

model TranscriptEntry {
  id          String   @id @default(cuid())
  sessionId   String
  speaker     String
  text        String
  timestamp   DateTime @default(now())
  isFinal     Boolean  @default(true)
  assistantId String?
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([timestamp])
  @@index([assistantId])
  @@index([sessionId], map: "TranscriptEntry_sessionId_count_idx")
}

model ProgressTracking {
  id                 String   @id @default(cuid())
  userId             String
  date               DateTime @default(now())
  closenessScore     Int
  communicationScore Int
  therapyType        String   @default("couple")
  notes              String?
  sessionId          String?
  assistantId        String?
  user               User     @relation(fields: [userId], references: [id])

  @@index([therapyType])
  @@index([assistantId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("AuthSession")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CommunicationMetrics {
  id                      String   @id @default(cuid())
  userId                  String
  date                    DateTime @default(now())
  activeListeningScore    Int
  expressingNeedsScore    Int
  conflictResolutionScore Int
  emotionalSupportScore   Int
  assistantId             String?
  user                    User     @relation(fields: [userId], references: [id])

  @@index([assistantId])
}

model TherapySession {
  id                String   @id @default(cuid())
  userId            String
  sessionDate       DateTime
  duration          Int
  notes             String?
  status            String   @default("scheduled")
  reminderSent      Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  notificationPrefs String?  @default("email")
  smsReminderSent   Boolean? @default(false)
  emailReminderSent Boolean? @default(false)
  user              User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionDate])
  @@index([status])
}
