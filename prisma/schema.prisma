generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  name                 String?
  password             String
  partnerName          String?
  relationshipStatus   String?                @default("Married")
  communicationMetrics CommunicationMetrics[]
  progressTracking     ProgressTracking[]
  sessions             Session[]
  therapySessions      TherapySession[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime
  duration     Int
  theme        String   @default("AI Therapy Session")
  notes        String?  @default("")
  status       String   @default("scheduled")
  reminderSent Boolean  @default(false)
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ProgressTracking {
  id                 String   @id @default(cuid())
  userId             String
  date               DateTime @default(now())
  closenessScore     Int
  communicationScore Int
  user               User     @relation(fields: [userId], references: [id])
}

model CommunicationMetrics {
  id                      String   @id @default(cuid())
  userId                  String
  date                    DateTime @default(now())
  activeListeningScore    Int
  expressingNeedsScore    Int
  conflictResolutionScore Int
  emotionalSupportScore   Int
  user                    User     @relation(fields: [userId], references: [id])
}

model TherapySession {
  id           String   @id @default(cuid())
  userId       String
  sessionDate  DateTime
  duration     Int
  notes        String?
  status       String   @default("scheduled")
  reminderSent Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionDate])
  @@index([status])
}
