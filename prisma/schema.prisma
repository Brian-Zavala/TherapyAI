generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                 String?
  password             String?
  image                String?
  emailVerified        DateTime?
  onboardingCompleted  Boolean               @default(false)
  onboardingData       Json?
  hasSeenIntro         Boolean               @default(false)
  welcomeMessageSent   Boolean               @default(false)
  welcomeMessageSentAt DateTime?
  isDeleted            Boolean               @default(false)
  deletedAt            DateTime?
  deletionReason       String?
  dataRetentionUntil   DateTime?
  canRecover           Boolean               @default(true)
  subscriptionStatus   String?               @default("free")
  subscriptionId       String?
  billingEmail         String?
  stripeCustomerId     String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  accounts             Account[]
  auditLogs            AuditLog[]
  authSessions         AuthSession[]
  calendarIntegrations CalendarIntegration[]
  communicationMetrics CommunicationMetric[]
  familyMembers        FamilyMember[]
  progressTracking     ProgressTracking[]
  smsOptOuts           SMSOptOut[]
  sessions             Session[]
  sessionMetrics       SessionMetrics[]
  therapyInsights      TherapyInsight[]
  profile              UserProfile?
  notificationTracking NotificationTracking[]
  maxSessionDuration   Int?                  @default(30)
  concurrentSessions   Int?                  @default(1)
  usageCredits         UsageCredits[]
  usageTransactions    UsageTransaction[]
  usageAlerts          UsageAlert[]

  @@index([email])
  @@index([createdAt])
  @@index([isDeleted, deletedAt])
  @@index([subscriptionStatus])
  @@index([dataRetentionUntil])
}

model UserProfile {
  id                   String    @id @default(cuid())
  userId               String    @unique
  pronouns             String?
  age                  Int?
  phone                String?
  emergencyContact     String?
  sessionPreference    String?
  communicationStyle   String?
  notificationPrefs    Json?     @default("[]")
  sessionFrequency     String?
  preferredDays        Json?
  recurringSession     String?
  reminderTiming       String?
  smsConsent           Boolean?  @default(false)
  smsConsentDate       DateTime?
  phoneValidated       Boolean?  @default(false)
  partnerName          String?
  partnerAge           Int?
  relationshipStatus   String?   @default("Married")
  currentConcerns      Json?
  additionalNotes      String?
  assistantId          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  aiDisclaimerAccepted Boolean   @default(false)
  aiDisclaimerDate     DateTime?
  aiDisclaimerVersion  String?
  timezone             String?   @default("UTC")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assistantId])
}

model FamilyMember {
  id                   String                @id @default(cuid())
  userId               String
  name                 String
  age                  Int?
  relationship         String
  order                Int                   @default(0)
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionFamilyMembers SessionFamilyMember[]

  @@unique([userId, name])
  @@index([userId, isActive])
  @@index([userId, order])
}

model Session {
  id                      String                @id @default(uuid())
  userId                  String
  assistantId             String?
  date                    DateTime
  startTime               DateTime?
  endTime                 DateTime?
  completedAt             DateTime?
  duration                Int                   @default(30)
  theme                   String                @default("AI Therapy Session")
  notes                   String?               @default("")
  status                  SessionStatus         @default(SCHEDULED)
  terminationReason       String?
  conversationTimeSeconds Int                   @default(0)
  lastConversationStart   DateTime?
  isPaused                Boolean               @default(false)
  pausedAt                DateTime?
  resumedAt               DateTime?
  totalPausedTimeSeconds  Int                   @default(0)
  pauseStartTime          DateTime?
  vapiCallId              String?
  vapiCallCost            Float?
  vapiRecordingUrl        String?
  reminderSent            Boolean               @default(false)
  smsReminderSent         Boolean?              @default(false)
  emailReminderSent       Boolean?              @default(false)
  oneHourReminderSent     Boolean?              @default(false)
  version                 Int                   @default(0)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  sessionType             SessionType           @default(SOLO)
  notificationToken       String?
  notificationTokenExpiry DateTime?
  startedViaNotification  Boolean               @default(false)
  notificationStartedAt   DateTime?
  creditsAllocated        Int?                  @default(0)
  creditsUsed             Int?                  @default(0)
  communicationMetrics    CommunicationMetric[]
  progressTracking        ProgressTracking[]
  user                    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionFamilyMembers    SessionFamilyMember[]
  sessionMetrics          SessionMetrics?
  therapyInsights         TherapyInsight[]
  transcriptEntries       TranscriptEntry[]
  conversationState       ConversationState?
  notificationTracking    NotificationTracking[]
  usageTransactions       UsageTransaction[]

  @@index([userId, status])
  @@index([userId, startTime])
  @@index([userId, sessionType])
  @@index([assistantId])
  @@index([status, startTime])
  @@index([notificationToken])
  @@index([completedAt])
}

model SessionFamilyMember {
  id                 String       @id @default(cuid())
  sessionId          String
  familyMemberId     String
  participationLevel String?      @default("active")
  createdAt          DateTime     @default(now())
  familyMember       FamilyMember @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  session            Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, familyMemberId])
  @@index([sessionId])
  @@index([familyMemberId])
}

model CommunicationMetric {
  id           String   @id @default(cuid())
  sessionId    String?
  userId       String
  clarity      Float    @default(50)
  empathy      Float    @default(50)
  respect      Float    @default(50)
  overall      Float    @default(50)
  listening    Float?   @default(50)
  expression   Float?   @default(50)
  metricType   String   @default("real-time")
  calculatedAt DateTime @default(now())
  confidence   Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  session      Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId, metricType])
  @@index([sessionId, calculatedAt])
  @@index([userId, calculatedAt])
  @@index([userId, metricType, calculatedAt])
}

model SessionMetrics {
  id                String   @id @default(cuid())
  sessionId         String   @unique
  userId            String
  duration          Int
  totalMessages     Int
  userMessages      Int
  assistantMessages Int
  engagementScore   Float
  sentimentScore    Float
  sentimentTrend    String
  topicsCovered     String[]
  emotionalInsights Json?
  completionRate    Float    @default(1.0)
  qualityScore      Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  session           Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ProgressTracking {
  id                 String   @id @default(cuid())
  userId             String
  sessionId          String?
  closenessScore     Int
  communicationScore Int
  notes              String?
  assistantId        String?
  date               DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  session            Session? @relation(fields: [sessionId], references: [id])
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])
  @@index([userId, date])
  @@index([assistantId])
}

model TranscriptEntry {
  id                 String   @id @default(cuid())
  sessionId          String
  speaker            String
  text               String
  timestamp          DateTime @default(now())
  isFinal            Boolean  @default(true)
  assistantId        String?
  sequence           Int?
  sentiment          String?
  emotionalIntensity Float?
  topics             Json?
  createdAt          DateTime @default(now())
  session            Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@index([sessionId, sequence])
  @@index([timestamp])
  @@index([assistantId])
}

model ConversationState {
  id               String                @id @default(cuid())
  sessionId        String                @unique
  userId           String
  assistantId      String
  variableValues   Json?
  metadata         Json?
  sessionStartTime DateTime
  lastActiveTime   DateTime
  totalDuration    Int                   @default(0)
  messageCount     Int                   @default(0)
  isActive         Boolean               @default(false)
  isPaused         Boolean               @default(true)
  expiresAt        DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  messages         ConversationMessage[]
  session          Session               @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, isPaused])
  @@index([userId, lastActiveTime])
  @@index([expiresAt])
  @@map("conversation_states")
}

model ConversationMessage {
  id                  String            @id @default(cuid())
  conversationStateId String
  role                String
  content             String
  timestamp           DateTime          @default(now())
  metadata            Json?
  conversationState   ConversationState @relation(fields: [conversationStateId], references: [id], onDelete: Cascade)

  @@index([conversationStateId, timestamp])
  @@map("conversation_messages")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("AuthSession")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires])
}

model SMSOptOut {
  id          String    @id @default(cuid())
  phoneNumber String
  userId      String?
  keyword     String
  optOutAt    DateTime  @default(now())
  optInAt     DateTime?
  active      Boolean   @default(true)
  source      String    @default("sms")
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User?     @relation(fields: [userId], references: [id])

  @@unique([phoneNumber, active])
  @@index([phoneNumber])
  @@index([userId])
  @@index([active, optOutAt])
}

model AuditLog {
  id              String    @id @default(cuid())
  userId          String?
  sessionId       String?
  action          String
  entityType      String
  entityId        String?
  oldValues       Json?
  newValues       Json?
  changedFields   String[]
  ipAddress       String?
  userAgent       String?
  requestId       String?
  metadata        Json?
  reason          String?
  complianceFlags String[]  @default([])
  isLegalHold     Boolean   @default(false)
  legalHoldUntil  DateTime?
  createdAt       DateTime  @default(now())
  user            User?     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([action, entityType])
  @@index([sessionId])
  @@index([createdAt])
  @@index([isLegalHold, legalHoldUntil])
}

model DataExportRequest {
  id                 String    @id @default(cuid())
  userId             String
  requestType        String    @default("full")
  status             String    @default("pending")
  format             String    @default("json")
  includeTranscripts Boolean   @default(true)
  includeMetrics     Boolean   @default(true)
  includeProfile     Boolean   @default(true)
  includeSessions    Boolean   @default(true)
  downloadUrl        String?
  expiresAt          DateTime?
  fileSize           Int?
  processedAt        DateTime?
  downloadedAt       DateTime?
  errorMessage       String?
  retryCount         Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([expiresAt])
}

model AccountRecovery {
  id              String    @id @default(cuid())
  userId          String    @unique
  email           String
  recoveryToken   String    @unique
  recoveryCode    String?
  expiresAt       DateTime
  userSnapshot    Json
  profileSnapshot Json?
  sessionCount    Int       @default(0)
  attemptCount    Int       @default(0)
  lastAttemptAt   DateTime?
  isRecovered     Boolean   @default(false)
  recoveredAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([recoveryToken])
  @@index([email, expiresAt])
  @@index([expiresAt, isRecovered])
}

model CalendarIntegration {
  id               String    @id @default(cuid())
  userId           String
  provider         String
  enabled          Boolean   @default(false)
  accountEmail     String?
  calendarId       String?
  accessToken      String?
  refreshToken     String?
  expiresAt        DateTime?
  lastSync         DateTime?
  syncStatus       String    @default("disconnected")
  errorMessage     String?
  providerMetadata Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId, enabled])
  @@index([provider, syncStatus])
  @@index([expiresAt])
}

model TherapyInsight {
  id              String   @id @default(cuid())
  sessionId       String?
  userId          String
  category        String
  title           String
  description     String
  priority        String   @default("medium")
  confidence      Float    @default(0.8)
  evidence        Json?
  recommendations Json?
  isRealTime      Boolean  @default(false)
  generatedAt     DateTime @default(now())
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  session         Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([sessionId, generatedAt])
  @@index([userId, generatedAt])
  @@index([isRealTime, generatedAt])
}

model Notification {
  id               String    @id @default(cuid())
  userId           String
  sessionId        String?
  type             String
  title            String
  message          String
  priority         String    @default("normal")
  deliveryMethod   String    @default("email")
  deliveryStatus   String    @default("pending")
  deliveryAttempts Int       @default(0)
  deliveredAt      DateTime?
  scheduledFor     DateTime?
  sentAt           DateTime?
  readAt           DateTime?
  actionUrl        String?
  actionTaken      String?
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId, type, deliveryStatus])
  @@index([userId, readAt])
  @@index([scheduledFor, deliveryStatus])
  @@index([sessionId])
}

model WebhookEvent {
  id            String    @id @default(cuid())
  webhookId     String    @unique
  messageType   String
  callId        String?
  sessionId     String?
  payload       Json
  status        String    @default("pending")
  processedAt   DateTime?
  error         String?
  retryCount    Int       @default(0)
  correlationId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([webhookId])
  @@index([sessionId])
  @@index([callId])
  @@index([status, createdAt])
  @@index([messageType, createdAt])
}

model TherapySession {
  id                String   @id @default(cuid())
  userId            String
  sessionDate       DateTime
  duration          Int
  notes             String?
  status            String   @default("scheduled")
  reminderSent      Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  notificationPrefs String?  @default("email")
  smsReminderSent   Boolean? @default(false)
  emailReminderSent Boolean? @default(false)

  @@index([userId])
  @@index([sessionDate])
  @@index([status])
}

enum SessionStatus {
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  TERMINATED
  ABANDONED
  TECHNICAL_ISSUE
}

enum SessionType {
  SOLO
  COUPLE
  FAMILY
}

model NotificationTracking {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  type      String   // 'email' or 'sms'
  action    String   // 'sent', 'clicked', 'started', 'completed'
  token     String?
  metadata  Json?
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@index([token])
}

// ========================================
// CREDIT & USAGE TRACKING
// ========================================

model UsageCredits {
  id                   String   @id @default(cuid())
  userId               String
  totalCredits         Int      @default(0)
  usedCredits          Int      @default(0)
  bonusCredits         Int      @default(0)
  billingPeriodStart   DateTime
  billingPeriodEnd     DateTime
  planType             String   // 'free', 'essential', 'growth', 'unlimited'
  subscriptionId       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  // Relations
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions         UsageTransaction[]
  
  @@index([userId, billingPeriodStart, billingPeriodEnd])
  @@index([userId, createdAt])
  @@index([planType])
}

model UsageTransaction {
  id          String          @id @default(cuid())
  userId      String
  creditId    String
  type        TransactionType
  amount      Int             // Minutes used/added/refunded
  balance     Int             // Remaining balance after transaction (-1 for unlimited)
  sessionId   String?
  vapiCallId  String?
  description String
  metadata    Json?
  createdAt   DateTime        @default(now())
  
  // Relations
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  credit      UsageCredits    @relation(fields: [creditId], references: [id], onDelete: Cascade)
  session     Session?        @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  
  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([vapiCallId])
  @@index([creditId, type])
}

model UsageAlert {
  id           String    @id @default(cuid())
  userId       String
  alertType    AlertType
  threshold    Int       // Percentage threshold (80, 90, 100)
  message      String
  acknowledged Boolean   @default(false)
  sentAt       DateTime  @default(now())
  
  // Relations
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, acknowledged])
  @@index([sentAt])
  @@index([alertType, threshold])
}

enum TransactionType {
  DEBIT    // Credits used for sessions
  BONUS    // Bonus credits added
  REFUND   // Credits refunded for technical issues
}

enum AlertType {
  LOW_CREDITS        // Warning when credits are low
  CREDITS_EXHAUSTED  // Alert when credits are fully used
  BILLING_REMINDER   // General billing reminders
}
