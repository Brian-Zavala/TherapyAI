generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  name                 String?
  password             String
  partnerName          String?
  relationshipStatus   String?                @default("Married")
  familyMember1        String?
  familyMember2        String?
  familyMember3        String?
  familyMember4        String?
  assistantId          String?                // Vapi assistant ID
  communicationMetrics CommunicationMetrics[]
  progressTracking     ProgressTracking[]
  soloTherapyMetrics   SoloTherapyMetrics[]
  familyTherapyMetrics FamilyTherapyMetrics[]
  sessions             Session[]
  therapySessions      TherapySession[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime
  duration     Int
  theme        String   @default("AI Therapy Session")
  notes        String?  @default("")
  status       String   @default("scheduled")
  reminderSent Boolean  @default(false)
  transcript   String?  @db.Text
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ProgressTracking {
  id                 String   @id @default(cuid())
  userId             String
  date               DateTime @default(now())
  closenessScore     Int
  communicationScore Int
  user               User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model RelationshipProgress {
  id            String   @id @default(cuid())
  userId        String
  week          Int
  date          DateTime @default(now())
  closeness     Float
  communication Float

  @@index([userId])
  @@index([week])
}

model CommunicationMetrics {
  id                      String   @id @default(cuid())
  userId                  String
  date                    DateTime @default(now())
  activeListeningScore    Int
  expressingNeedsScore    Int
  conflictResolutionScore Int
  emotionalSupportScore   Int
  user                    User     @relation(fields: [userId], references: [id])
  
  @@index([userId])
}

model SoloTherapyMetrics {
  id                       String   @id @default(cuid())
  userId                   String
  date                     DateTime @default(now())
  selfAwarenessScore       Int
  emotionalRegulationScore Int
  personalGrowthScore      Int
  copingSkillsScore        Int
  user                     User     @relation(fields: [userId], references: [id])
  
  @@index([userId])
}

model FamilyTherapyMetrics {
  id                       String   @id @default(cuid())
  userId                   String
  date                     DateTime @default(now())
  familyCommunicationScore Int
  roleDefinitionScore      Int
  conflictManagementScore  Int
  familyBondingScore       Int
  user                     User     @relation(fields: [userId], references: [id])
  
  @@index([userId])
}

model TherapySession {
  id           String   @id @default(cuid())
  userId       String
  sessionDate  DateTime
  duration     Int
  notes        String?
  status       String   @default("scheduled")
  reminderSent Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionDate])
  @@index([status])
}
