generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  name                 String?
  password             String?
  partnerName          String?
  relationshipStatus   String?                @default("Married")
  assistantId          String?
  familyMember1        String?
  familyMember2        String?
  familyMember3        String?
  familyMember4        String?
  pronouns             String?
  therapyType          String?
  currentConcerns      Json?
  emergencyContact     String?
  sessionPreference    String?
  communicationStyle   String?
  additionalNotes      String?
  image                String?
  emailVerified        DateTime?
  onboardingCompleted  Boolean                @default(false)
  onboardingData       Json?
  phone                String?
  notificationPrefs    String?                @default("email")
  accounts             Account[]
  authSessions         AuthSession[]
  communicationMetrics CommunicationMetrics[]
  progressTracking     ProgressTracking[]
  sessions             Session[]
  therapySessions      TherapySession[]
}

model Session {
  id                String            @id @default(uuid())
  userId            String
  date              DateTime
  duration          Int
  theme             String            @default("AI Therapy Session")
  notes             String?           @default("")
  status            String            @default("scheduled")
  reminderSent      Boolean           @default(false)
  transcript        String?
  notificationPrefs String?           @default("email")
  smsReminderSent   Boolean           @default(false)
  emailReminderSent Boolean           @default(false)
  user              User              @relation(fields: [userId], references: [id])
  transcriptEntries TranscriptEntry[]

  @@index([userId])
}

model TranscriptEntry {
  id        String   @id @default(cuid())
  sessionId String
  speaker   String
  text      String
  timestamp DateTime @default(now())
  isFinal   Boolean  @default(true)
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([timestamp])
}

model ProgressTracking {
  id                 String   @id @default(cuid())
  userId             String
  date               DateTime @default(now())
  closenessScore     Int
  communicationScore Int
  therapyType        String   @default("couple")
  notes              String?
  sessionId          String?
  user               User     @relation(fields: [userId], references: [id])

  @@index([therapyType])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("AuthSession")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CommunicationMetrics {
  id                      String   @id @default(cuid())
  userId                  String
  date                    DateTime @default(now())
  activeListeningScore    Int
  expressingNeedsScore    Int
  conflictResolutionScore Int
  emotionalSupportScore   Int
  user                    User     @relation(fields: [userId], references: [id])
}

model TherapySession {
  id                String   @id @default(cuid())
  userId            String
  sessionDate       DateTime
  duration          Int
  notes             String?
  status            String   @default("scheduled")
  reminderSent      Boolean  @default(false)
  notificationPrefs String?  @default("email")
  smsReminderSent   Boolean  @default(false)
  emailReminderSent Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionDate])
  @@index([status])
}
