generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CommunicationMetrics {
  id                      String   @id
  userId                  String
  date                    DateTime @default(now())
  activeListeningScore    Int
  expressingNeedsScore    Int
  conflictResolutionScore Int
  emotionalSupportScore   Int
  assistantId             String?
  User                    User     @relation(fields: [userId], references: [id])

  @@index([assistantId])
}

model ProgressTracking {
  id                 String   @id
  userId             String
  date               DateTime @default(now())
  closenessScore     Int
  communicationScore Int
  therapyType        String   @default("couple")
  notes              String?
  sessionId          String?
  assistantId        String?
  User               User     @relation(fields: [userId], references: [id])

  @@index([assistantId])
  @@index([therapyType])
}

model Session {
  id                      String               @id
  userId                  String
  date                    DateTime
  duration                Int
  theme                   String               @default("AI Therapy Session")
  notes                   String?              @default("")
  status                  String               @default("scheduled")
  reminderSent            Boolean              @default(false)
  transcript              String?
  notificationPrefs       String?              @default("email")
  smsReminderSent         Boolean?             @default(false)
  emailReminderSent       Boolean?             @default(false)
  assistantId             String?
  oneHourReminderSent     Boolean?             @default(false)
  startTime               DateTime?
  conversationTimeSeconds Int                  @default(0)
  lastConversationStart   DateTime?
  isPaused                Boolean              @default(false)
  pausedAt                DateTime?
  resumedAt               DateTime?
  totalPausedTimeSeconds  Int                  @default(0)
  pauseStartTime          DateTime?
  User                    User                 @relation(fields: [userId], references: [id])
  TranscriptEntry         TranscriptEntry[]
  conversation_states     conversation_states?

  @@index([assistantId])
  @@index([userId])
}

model TherapySession {
  id                String   @id
  userId            String
  sessionDate       DateTime
  duration          Int
  notes             String?
  status            String   @default("scheduled")
  reminderSent      Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  notificationPrefs String?  @default("email")
  smsReminderSent   Boolean? @default(false)
  emailReminderSent Boolean? @default(false)
  User              User     @relation(fields: [userId], references: [id])

  @@index([sessionDate])
  @@index([status])
  @@index([userId])
}

model TranscriptEntry {
  id          String   @id
  sessionId   String
  speaker     String
  text        String
  timestamp   DateTime @default(now())
  isFinal     Boolean  @default(true)
  assistantId String?
  Session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([assistantId])
  @@index([sessionId], map: "TranscriptEntry_sessionId_count_idx")
  @@index([sessionId])
  @@index([timestamp])
}

model User {
  id                    String                 @id
  email                 String                 @unique
  name                  String?
  password              String?
  partnerName           String?
  relationshipStatus    String?                @default("Married")
  assistantId           String?
  familyMember1         String?
  familyMember2         String?
  familyMember3         String?
  familyMember4         String?
  image                 String?
  emailVerified         DateTime?
  onboardingCompleted   Boolean                @default(false)
  onboardingData        Json?
  pronouns              String?
  therapyType           String?
  currentConcerns       Json?
  emergencyContact      String?
  sessionPreference     String?
  communicationStyle    String?
  additionalNotes       String?
  phone                 String?
  notificationPrefs     String?                @default("email")
  age                   Int?
  partnerAge            Int?
  familyMember1Age      Int?
  familyMember2Age      Int?
  familyMember3Age      Int?
  familyMember4Age      Int?
  hasSeenIntro          Boolean                @default(false)
  familyMember1Relation String?
  familyMember2Relation String?
  familyMember3Relation String?
  familyMember4Relation String?
  familyMember5         String?
  familyMember5Age      Int?
  familyMember5Relation String?
  familyMember6         String?
  familyMember6Age      Int?
  familyMember6Relation String?
  familyMember7         String?
  familyMember7Age      Int?
  familyMember7Relation String?
  preferredDays         Json?
  recurringSession      String?
  reminderTiming        String?
  sessionFrequency      String?
  Account               Account[]
  AuthSession           AuthSession[]
  CommunicationMetrics  CommunicationMetrics[]
  ProgressTracking      ProgressTracking[]
  Session               Session[]
  TherapySession        TherapySession[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model conversation_messages {
  id                  String              @id
  conversationStateId String
  role                String
  content             String
  timestamp           DateTime            @default(now())
  metadata            Json?
  conversation_states conversation_states @relation(fields: [conversationStateId], references: [id], onDelete: Cascade)

  @@index([conversationStateId, timestamp])
}

model conversation_states {
  id                    String                  @id
  sessionId             String                  @unique
  userId                String
  assistantId           String
  variableValues        Json?
  metadata              Json?
  sessionStartTime      DateTime
  lastActiveTime        DateTime
  totalDuration         Int                     @default(0)
  messageCount          Int                     @default(0)
  isActive              Boolean                 @default(false)
  isPaused              Boolean                 @default(true)
  expiresAt             DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  conversation_messages conversation_messages[]
  Session               Session                 @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId, isPaused])
  @@index([userId, lastActiveTime])
}
