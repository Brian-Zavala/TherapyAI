# Database
DATABASE_URL="postgresql://..."

# VAPI Configuration
# Public key for Web SDK (starts with pk_)
NEXT_PUBLIC_VAPI_PUBLIC_KEY="pk_your_public_key_here"

# For JWT generation (optional, only if not using public key)
VAPI_PRIVATE_KEY="your_private_key_here"
VAPI_ORG_ID="your_org_id_here"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-key"

# Email
RESEND_API_KEY="re_your_api_key"

# Analytics
NEXT_PUBLIC_POSTHOG_KEY="phc_your_key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Redis (optional)
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"