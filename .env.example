# Database
DATABASE_URL="postgresql://user:password@localhost:5432/therapy_db?pgbouncer=true&connection_limit=1"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# VAPI
VAPI_API_KEY=your-vapi-api-key
VAPI_ORG_ID=your-vapi-org-id
VAPI_PHONE_NUMBER=+1234567890
VAPI_WEBHOOK_SECRET=your-webhook-secret

# Email (Resend)
RESEND_API_KEY=re_your_api_key

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Transcript Strategy Configuration
# Controls how transcripts are saved to avoid duplicates
# Options: 'true' (use webhooks as source) or 'false' (use realtime as source)
NEXT_PUBLIC_USE_WEBHOOK_TRANSCRIPTS=false

# Enable/disable real-time transcript saving
# Set to 'false' when using webhook mode to prevent duplicates
NEXT_PUBLIC_ENABLE_REALTIME_SAVING=true

# Enable/disable transcript reconciliation
# Automatically detects and removes duplicate transcripts
NEXT_PUBLIC_ENABLE_TRANSCRIPT_RECONCILIATION=true

# Monitoring & Logging
NEXT_PUBLIC_LOG_LEVEL=info
SENTRY_DSN=https://your-sentry-dsn

# Feature Flags
NEXT_PUBLIC_ENABLE_VOICE_THERAPY=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_SCHEDULING=true

# CDN Configuration (Bunny)
BUNNY_CDN_URL=https://your-cdn.b-cdn.net
BUNNY_API_KEY=your-bunny-api-key

# Twilio (for SMS)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI (for AI features)
OPENAI_API_KEY=sk-your-openai-key

# Environment
NODE_ENV=development