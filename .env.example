# Database
# IMPORTANT: Add connection pooling parameters for better performance
# Original format:
# DATABASE_URL="postgresql://user:password@host:port/database"
#
# Optimized format with connection pooling (reduces connection time by 30%):
DATABASE_URL="postgresql://user:password@host:port/database?pgbouncer=true&connection_limit=20&pool_timeout=30&statement_cache_size=0"

# For Supabase users, use this format:
# DATABASE_URL="postgresql://postgres.[PROJECT_ID]:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true&connection_limit=20"

# For Railway users, append these parameters to your existing URL:
# ?pgbouncer=true&connection_limit=20&pool_timeout=30

# VAPI Configuration
# Public key for Web SDK (starts with pk_)
NEXT_PUBLIC_VAPI_PUBLIC_KEY="pk_your_public_key_here"

# For JWT generation (optional, only if not using public key)
VAPI_PRIVATE_KEY="your_private_key_here"
VAPI_ORG_ID="your_org_id_here"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-key"

# Email
RESEND_API_KEY="re_your_api_key"

# Analytics
NEXT_PUBLIC_POSTHOG_KEY="phc_your_key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Redis (optional)
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# AI Insights (optional - uses deterministic insights by default)
# The app now includes a comprehensive evidence-based insight system that doesn't require AI
# Only add this if you want AI-enhanced insights (costs ~$0.003 per generation)
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-api03-your-key-here"

# Force deterministic insights even if ANTHROPIC_API_KEY is set (recommended for production)
USE_DETERMINISTIC_INSIGHTS="true"

# Development Logging (optional)
# Set to "true" to enable verbose logging in development
PRISMA_VERBOSE="false"   # Prisma connection lifecycle logs
DEBUG_BATCH="false"      # Batch endpoint debug logs